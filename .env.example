# === Neon Postgres ===
DB_HOST=your-neon-host.neon.tech
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=your_password
DB_PORT=5432
DB_SSLMODE=require

# === DagsHub MLflow ===
# URI format: https://dagshub.com/<your-user>/<repo-name>.mlflow
MLFLOW_TRACKING_URI=https://dagshub.com/your-user/property-ai-lab.mlflow
MLFLOW_TRACKING_USERNAME=your-dagshub-user
MLFLOW_TRACKING_PASSWORD=your-dagshub-token
